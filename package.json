{
  "name": "@motion-core/docs-template-monorepo",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "docs:changelog": "node ./scripts/generate-changelog-docs.mjs",
    "dev": "bun run --cwd apps/web dev",
    "build": "bun run --cwd apps/web build",
    "preview": "bun run --cwd apps/web preview",
    "deploy:web": "bun run --cwd apps/web deploy",
    "check": "bun run --cwd apps/web check",
    "test": "bun run --cwd apps/web test --passWithNoTests",
    "lint": "bun run --cwd apps/web lint",
    "format": "bun run --cwd apps/web format",
    "format:check": "bun run --cwd apps/web format:check"
  },
  "dependencies": {
    "prettier-plugin-tailwindcss": "^0.7.2"
  }
}
