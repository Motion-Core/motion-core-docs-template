{
  "name": "motion-gpu-monorepo",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "bun run dev:web",
    "build": "bun run build:web",
    "preview": "bun run --cwd apps/web preview",
    "deploy:web": "bun run --cwd apps/web deploy",
    "check": " bun run check:web",
    "test": "bun run build:motion-gpu",
    "lint": "bun run lint:web",
    "format": "bun run --cwd apps/web format"
  },
  "dependencies": {
    "prettier-plugin-tailwindcss": "^0.7.2"
  }
}
