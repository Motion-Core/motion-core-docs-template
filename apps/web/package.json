{
	"name": "@motion-core/docs-template",
	"version": "0.1.1",
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@sveltejs/adapter-cloudflare": "^7.2.8",
		"@sveltejs/kit": "^2.53.0",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@tailwindcss/vite": "^4.1.17",
		"@types/node": "^25.5.0",
		"@typescript-eslint/eslint-plugin": "^8.56.1",
		"@typescript-eslint/parser": "^8.56.1",
		"eslint": "^10.0.2",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.15.0",
		"globals": "^17.4.0",
		"mdsvex": "^0.12.6",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.5.0",
		"rehype-pretty-code": "^0.14.1",
		"shiki": "^4.0.1",
		"svelte": "^5.53.2",
		"svelte-check": "^4.3.4",
		"tailwindcss": "^4.1.18",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.56.1",
		"vite": "^7.2.7",
		"vitest": "^4.0.18",
		"wrangler": "^4.72.0"
	},
	"private": true,
	"scripts": {
		"docs:changelog": "node ../../scripts/generate-changelog-docs.mjs",
		"predev": "bun run docs:changelog",
		"dev": "vite dev",
		"prebuild": "bun run docs:changelog",
		"build": "vite build && node ./scripts/patch-cloudflare-worker-wasm.mjs",
		"preview": "vite preview",
		"preview:cf": "bun run build && wrangler dev",
		"preview:cf:remote": "bun run build && wrangler dev --remote",
		"deploy": "bun run build && wrangler deploy",
		"cf-typegen": "wrangler types",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"test": "vitest run",
		"test:watch": "vitest",
		"lint": "eslint .",
		"format": "prettier --write .",
		"format:check": "prettier --check ."
	},
	"type": "module",
	"dependencies": {
		"@fontsource/inter": "^5.2.8",
		"@resvg/resvg-wasm": "^2.6.2",
		"carbon-icons-svelte": "^13.9.0",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"satori": "^0.25.0",
		"satori-html": "^0.3.2",
		"tailwind-merge": "^3.5.0"
	}
}
